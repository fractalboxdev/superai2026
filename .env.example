# Template of required env vars. Copy to `.env.local` for local dev and fill in.
# Production values live ENCRYPTED in `.env.production` (committed, decrypted via dotenvx).
# Never put real secrets in this file — it is committed in plaintext.

# --- Vercel ---
# API token for deploys/automation (vcp_...). Keep server-side only.
VERCEL_TOKEN=

# --- AWS ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=

# --- Stripe ---
# Publishable key (client-safe). Secret key is server-only — never client-exposed.
VITE_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=

# --- HyperDX (observability) ---
# Server APM ingestion key (read by apps/web observability.server.ts).
HYPERDX_API_KEY=
# Browser RUM key (client-exposed, inlined at build). Usually the same key.
VITE_HYPERDX_API_KEY=
# Service name shown in HyperDX. Browser RUM uses VITE_OTEL_SERVICE_NAME.
OTEL_SERVICE_NAME=contextful-web
VITE_OTEL_SERVICE_NAME=contextful-web-browser
# OTLP collector endpoint. HyperDX Cloud default below; override for self-hosted.
OTEL_EXPORTER_OTLP_ENDPOINT=https://in-otel.hyperdx.io

# --- Exa (search API) ---
EXA_API_KEY=

# --- Slack (Contextful ingestion app — infra/slack/) ---
# App-level OAuth credentials (server-only; used for OAuth install / request verification).
SLACK_APP_ID=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
# Bot User OAuth Token (xoxb-...) — what `sync ingest --source slack` reads.
SLACK_BOT_TOKEN=

# --- Neon Postgres ---
# Recommended for most uses (pooled)
DATABASE_URL=
# Direct connection without pgbouncer (migrations, etc.)
DATABASE_URL_UNPOOLED=

# Discrete connection parameters
PGHOST=
PGHOST_UNPOOLED=
PGUSER=
PGDATABASE=
PGPASSWORD=

# Vercel Postgres template vars
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=
POSTGRES_URL_NO_SSL=
POSTGRES_PRISMA_URL=
