# Template of required env vars. Copy to `.env.local` for local dev and fill in.
# Production values live ENCRYPTED in `.env.production` (committed, decrypted via dotenvx).
# Never put real secrets in this file — it is committed in plaintext.

# --- Vercel ---
# API token for deploys/automation (vcp_...). Keep server-side only.
VERCEL_TOKEN=

# --- AWS ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=

# --- Stripe ---
# Publishable key (client-safe). Secret key is server-only — never NEXT_PUBLIC_.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=

# --- HyperDX (observability) ---
# Ingestion key. For browser RUM, also expose as NEXT_PUBLIC_HYPERDX_API_KEY.
HYPERDX_API_KEY=

# --- Exa (search API) ---
EXA_API_KEY=

# --- Neon Postgres ---
# Recommended for most uses (pooled)
DATABASE_URL=
# Direct connection without pgbouncer (migrations, etc.)
DATABASE_URL_UNPOOLED=

# Discrete connection parameters
PGHOST=
PGHOST_UNPOOLED=
PGUSER=
PGDATABASE=
PGPASSWORD=

# Vercel Postgres template vars
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=
POSTGRES_URL_NO_SSL=
POSTGRES_PRISMA_URL=
