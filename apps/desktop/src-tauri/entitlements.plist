<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- Minimal entitlements (spec 10 §7): outbound/inbound network for the relay
     and tailnet, nothing else. App Sandbox stays off — the host must spawn the
     bundled sync binary and bind the relay port; hardened runtime + notarization
     are the mitigations. -->
<plist version="1.0">
<dict>
  <key>com.apple.security.network.client</key>
  <true/>
  <key>com.apple.security.network.server</key>
  <true/>
</dict>
</plist>
