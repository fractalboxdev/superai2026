---
import "@superai2026/design-system/styles.css";
import SiteNav from "../components/SiteNav.astro";

interface Props {
  title: string;
  description: string;
  /** Breadcrumb trail after "Docs"; omit on the docs index itself. */
  pageName?: string;
  /** Set for article pages to emit TechArticle JSON-LD + the .md alternate. */
  markdownPath?: string;
}

const { title, description, pageName, markdownPath } = Astro.props;

const site = Astro.site ?? new URL("https://www.contextful.work");
const canonical = new URL(Astro.url.pathname, site).toString();
const ogImage = new URL("/og.svg", site).toString();
const demoUrl = "https://demo.contextful.work";

const breadcrumb = [
  { name: "Home", item: site.origin + "/" },
  { name: "Docs", item: new URL("/docs/", site).toString() },
  ...(pageName ? [{ name: pageName, item: canonical }] : []),
];

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": `${site.origin}/#org`,
      name: "Contextful",
      url: site.origin,
      logo: new URL("/favicon.svg", site).toString(),
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: breadcrumb.map((b, i) => ({
        "@type": "ListItem",
        position: i + 1,
        name: b.name,
        item: b.item,
      })),
    },
    ...(pageName
      ? [
          {
            "@type": "TechArticle",
            headline: title,
            description,
            url: canonical,
            author: { "@id": `${site.origin}/#org` },
            publisher: { "@id": `${site.origin}/#org` },
          },
        ]
      : []),
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — Contextful</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {markdownPath && <link rel="alternate" type="text/markdown" href={markdownPath} />}
    <meta name="theme-color" content="#f8fafc" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#020617" media="(prefers-color-scheme: dark)" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="article" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@500;600&display=swap"
      rel="stylesheet"
    />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>

  <body>
    <SiteNav />

    <main class="docs">
      <div class="cf-container docs__inner">
        <slot />
      </div>
    </main>

    <footer class="footer">
      <div class="cf-container footer__inner">
        <span class="brand__name">Contextful</span>
        <nav class="footer__links" aria-label="Footer">
          <a href="/">Home</a>
          <a href="/docs/">Docs</a>
          <a href={demoUrl}>Demo</a>
          <a href="/llms-full.txt">llms-full.txt</a>
        </nav>
        <p class="footer__legal">Your data. Your rules. Runs on your machines.</p>
      </div>
    </footer>

    <style>
      .brand__name { font-weight: var(--weight-bold); }

      .docs { padding-block: var(--space-12) var(--space-24); }
      .docs__inner { max-width: var(--container-prose, 68ch); margin-inline: auto; }

      .footer { border-top: 1px solid var(--color-border); padding-block: var(--space-12); }
      .footer__inner { display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: var(--space-4); }
      .footer__links { display: flex; gap: var(--space-5); }
      .footer__links a { color: var(--color-text-muted); font-size: var(--text-sm); }
      .footer__legal { width: 100%; font-size: var(--text-sm); color: var(--color-text-subtle); }
    </style>

    <style is:global>
      /* Long-form docs typography over the rendered Markdown. */
      .docs__inner h1 { font-size: var(--text-4xl); line-height: 1.15; margin-bottom: var(--space-5); }
      .docs__inner h2 { font-size: var(--text-2xl); margin-top: var(--space-10); margin-bottom: var(--space-4); }
      .docs__inner h3 { font-size: var(--text-lg); margin-top: var(--space-8); margin-bottom: var(--space-3); }
      .docs__inner p, .docs__inner li { color: var(--color-text-muted); line-height: 1.7; }
      .docs__inner p { margin-block: var(--space-4); }
      .docs__inner ul, .docs__inner ol { padding-left: 1.25rem; margin-block: var(--space-4); display: grid; gap: var(--space-2); }
      .docs__inner a { color: var(--color-primary); }
      .docs__inner strong { color: var(--color-text); }
      .docs__inner pre {
        background: color-mix(in srgb, var(--color-text) 5%, var(--color-surface));
        border: 1px solid var(--color-border);
        border-radius: var(--radius-md, 8px);
        padding: var(--space-4);
        overflow-x: auto;
        font-size: var(--text-sm);
        margin-block: var(--space-5);
      }
      .docs__inner code { font-family: var(--font-mono); font-size: 0.92em; }
      .docs__inner p code, .docs__inner li code {
        background: color-mix(in srgb, var(--color-text) 7%, transparent);
        border-radius: 4px;
        padding: 0.1em 0.35em;
      }
      .docs__inner blockquote {
        border-left: 3px solid var(--color-primary);
        margin-block: var(--space-5);
        padding-left: var(--space-4);
        color: var(--color-text-muted);
      }
      .docs-diagram { margin-block: var(--space-6); display: flex; justify-content: center; }
      .docs-diagram svg { max-width: 100%; height: auto; }
    </style>

    <script>
      // Progressive enhancement: render ```mermaid fences as diagrams.
      // Crawlers and no-JS readers keep the diagram source as a code block.
      const blocks = document.querySelectorAll("pre > code.language-mermaid");
      if (blocks.length) {
        const { default: mermaid } = await import("mermaid");
        const dark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        mermaid.initialize({ startOnLoad: false, theme: dark ? "dark" : "neutral" });
        let i = 0;
        for (const code of blocks) {
          const pre = code.parentElement;
          if (!pre) continue;
          try {
            const { svg } = await mermaid.render(`docs-mmd-${i++}`, code.textContent ?? "");
            const fig = document.createElement("figure");
            fig.className = "docs-diagram";
            fig.innerHTML = svg;
            pre.replaceWith(fig);
          } catch {
            /* keep the source block visible */
          }
        }
      }
    </script>
  </body>
</html>
