---
import "@superai2026/design-system/styles.css";
import { existsSync } from "node:fs";
import { fileURLToPath } from "node:url";
import sharp from "sharp";
import { arts as artManifest } from "../../arts.manifest.mjs";

// Build-time lookup: an art slot renders only once its file has been
// generated into public/arts/ (see scripts/generate-arts.mjs). Dimensions
// come from the file itself — generated arts are trimmed to their silhouette.
const artFiles = new Map();
for (const entry of artManifest) {
  const file = new URL(`../../public/arts/${entry.id}.png`, import.meta.url);
  if (!existsSync(file)) continue;
  const meta = await sharp(fileURLToPath(file)).metadata();
  artFiles.set(entry.id, {
    src: `/arts/${entry.id}.png`,
    alt: entry.alt,
    width: meta.width,
    height: meta.height,
  });
}
const art = (id: string) => artFiles.get(id) ?? null;
const heroArt = art("hero");
const howArt = art("how-banner");
const logoArt = art("logo");

const title = "Contextful — local-first company brain";
const description =
  "Every teammate and every AI agent sees exactly the context they're permitted to — scoped by capability. Local-first, collaborative, on-prem. No SuperAgent.";
const site = Astro.site ?? new URL("https://www.contextful.work");
const canonical = new URL(Astro.url.pathname, site).toString();
const ogImage = new URL("/og.svg", site).toString();

const demoUrl = "https://demo.contextful.work";
// TODO: replace with the published Google Slides deck URL.
const slidesUrl = "https://docs.google.com/presentation/";

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": `${site.origin}/#org`,
      name: "Contextful",
      url: site.origin,
      logo: new URL("/favicon.svg", site).toString(),
    },
    {
      "@type": "WebSite",
      "@id": `${site.origin}/#website`,
      url: site.origin,
      name: "Contextful",
      description,
      publisher: { "@id": `${site.origin}/#org` },
    },
    {
      "@type": "SoftwareApplication",
      name: "Contextful",
      applicationCategory: "BusinessApplication",
      operatingSystem: "macOS, Web",
      description,
      offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
    },
  ],
};

const features = [
  {
    art: "feature-scoped",
    title: "Capability-scoped access",
    body: "Agents inherit a subset of your permissions — never more. The CTO's agent can't read the CEO's salary, provably. Delegation is attenuation, not trust.",
  },
  {
    art: "feature-brain",
    title: "A brain that grows",
    body: "Contextful ingests your tools, synthesizes context, flags anomalies, and learns from last month's mistakes — then answers questions over MCP.",
  },
  {
    art: "feature-local",
    title: "Local-first & on-prem",
    body: "Runs on your machine over Tailscale. Cloud is optional — used only for sync transport and LLM inference. Your context stays yours.",
  },
  {
    art: "feature-collab",
    title: "Real-time collaboration",
    body: "Humans and agents edit the same document together as peers, with live presence — powered by CRDT sync that works offline.",
  },
];

const steps = [
  { n: "01", title: "Share a document", body: "Create a doc and invite teammates and their agents into a shared, real-time workspace." },
  { n: "02", title: "Delegate scoped access", body: "Grant your agent a narrow slice of your permissions. It asks for more only when it needs to." },
  { n: "03", title: "Ask the company brain", body: "Agents answer from synthesized context — capability-filtered, with the parts you can't see redacted." },
];

const tools = ["Claude", "Notion", "Slack", "Linear", "AWS", "Vercel", "Stripe"];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#f8fafc" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#020617" media="(prefers-color-scheme: dark)" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>

  <body>
    <header class="nav">
      <div class="cf-container nav__inner">
        <a class="brand" href="/" aria-label="Contextful home">
          {logoArt ? (
            <img class="brand__mark" src={logoArt.src} alt="" width={logoArt.width} height={logoArt.height} />
          ) : (
            <svg class="brand__mark" viewBox="0 0 32 32" aria-hidden="true">
              <defs>
                <linearGradient id="navmark" x1="0" y1="0" x2="32" y2="32" gradientUnits="userSpaceOnUse">
                  <stop offset="0" stop-color="#6366f1" />
                  <stop offset="1" stop-color="#0ea5e9" />
                </linearGradient>
              </defs>
              <rect width="32" height="32" rx="8" fill="url(#navmark)" />
              <path d="M22 11.4a7 7 0 1 0 0 9.2" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" />
              <circle cx="22.6" cy="16" r="2.6" fill="#f59e0b" />
            </svg>
          )}
          <span class="brand__name">Contextful</span>
        </a>
        <nav class="nav__links" aria-label="Primary">
          <a href="#features">Product</a>
          <a href="#how">How it works</a>
          <a href="#demo">Demo</a>
          <a class="cf-btn cf-btn--primary cf-btn--sm" href={demoUrl}>Open the demo →</a>
        </nav>
      </div>
    </header>

    <main>
      <!-- Hero -->
      <section class="hero">
        <div class="orb orb--indigo hero__orb--1 cf-float" aria-hidden="true"></div>
        <div class="orb orb--sky hero__orb--2 cf-float" aria-hidden="true"></div>
        <div class="cf-container hero__inner">
          <div class="hero__copy cf-reveal">
            <span class="cf-eyebrow">Local-first company brain</span>
            <h1 class="hero__title">
              The company brain that keeps <span class="cf-text-gradient">every agent in its lane.</span>
            </h1>
            <p class="hero__sub">
              Contextful gives every teammate — and every AI agent — exactly the context they're
              permitted to see. No omniscient SuperAgent. No accidental leaks. Local-first,
              collaborative, scoped by capability.
            </p>
            <div class="hero__cta">
              <a class="cf-btn cf-btn--primary cf-btn--lg" href={demoUrl}>Watch the demo</a>
              <a class="cf-btn cf-btn--secondary cf-btn--lg" href={slidesUrl}>See the deck</a>
            </div>
            <p class="hero__note">Runs on-prem over Tailscale · Cloud optional</p>
          </div>

          <!-- Product glimpse -->
          <aside class="hero__visual" aria-hidden="true">
          {heroArt && (
            <img
              class="cf-art hero__art cf-float cf-reveal--fade"
              style="--cf-float-dur: 9s; --cf-float-amp: 14px; --cf-float-tilt: 0.6deg;"
              src={heroArt.src}
              alt=""
              width={heroArt.width}
              height={heroArt.height}
              loading="eager"
              fetchpriority="high"
            />
          )}
          <div
            class="glimpse cf-card cf-card--raised cf-float cf-reveal--fade"
            style="--cf-float-dur: 7s; --cf-float-delay: -3s; --cf-float-amp: 8px; --cf-float-tilt: -0.4deg; --cf-reveal-delay: 180ms;"
          >
            <div class="glimpse__head">
              <span class="glimpse__title">Q3 FinOps Review</span>
              <span class="cf-presence">
                <span class="cf-presence__dot" style="background:var(--cf-indigo-500)">CT</span>
                <span class="cf-presence__dot" style="background:var(--cf-sky-500)">CF</span>
                <span class="cf-presence__dot" style="background:var(--cf-amber-500)">◆</span>
              </span>
            </div>
            <p class="glimpse__line">Is this month's Claude spend justified after credits?</p>
            <div class="glimpse__answer">
              <span class="cf-badge cf-badge--primary">CFO agent · spend_by_team</span>
              <span class="cf-badge cf-badge--danger">salary · redacted</span>
              <p>Net spend after credits is down 18% MoM; utilization up 31%.</p>
            </div>
          </div>
          </aside>
        </div>
      </section>

      <!-- Trust strip -->
      <section class="strip">
        <div class="cf-container cf-reveal">
          <p class="strip__label">Brings your stack into one capability-scoped brain</p>
          <ul class="strip__tools">
            {tools.map((t) => <li>{t}</li>)}
          </ul>
        </div>
      </section>

      <!-- Features -->
      <section id="features" class="section">
        <div class="cf-container">
          <header class="section__head cf-reveal">
            <span class="cf-eyebrow">Why Contextful</span>
            <h2>Context, with consent.</h2>
            <p class="section__lead">
              The opposite of one all-knowing agent: partial, attenuated, auditable context per person
              and per agent — synthesized into a brain you can actually trust.
            </p>
          </header>
          <div class="grid grid--2">
            {features.map((f, i) => {
              const a = art(f.art);
              return (
                <article class="cf-card cf-card--interactive cf-reveal" style={`--cf-reveal-delay: ${i * 90}ms;`}>
                  {a && (
                    <img
                      class="cf-art card__art cf-float cf-reveal--fade"
                      style={`--cf-float-dur: ${7 + i}s; --cf-float-delay: -${i * 1.7}s; --cf-reveal-delay: ${i * 90 + 120}ms;`}
                      src={a.src}
                      alt={a.alt}
                      width={a.width}
                      height={a.height}
                      loading="lazy"
                    />
                  )}
                  <h3>{f.title}</h3>
                  <p class="cf-text-muted">{f.body}</p>
                </article>
              );
            })}
          </div>
        </div>
      </section>

      <!-- How it works -->
      <section id="how" class="section section--alt">
        <div class="orb orb--amber how__orb cf-float" aria-hidden="true"></div>
        <div class="cf-container">
          {howArt && (
            <img
              class="cf-art how__art cf-float cf-reveal--fade"
              style="--cf-float-dur: 11s; --cf-float-amp: 10px; --cf-float-tilt: 0.4deg;"
              src={howArt.src}
              alt={howArt.alt}
              width={howArt.width}
              height={howArt.height}
              loading="lazy"
            />
          )}
          <header class="section__head cf-reveal">
            <span class="cf-eyebrow">How it works</span>
            <h2>Share. Delegate. Ask.</h2>
          </header>
          <ol class="grid grid--3 steps">
            {steps.map((s, i) => (
              <li class="cf-card step cf-reveal" style={`--cf-reveal-delay: ${i * 110}ms;`}>
                <span class="step__n">{s.n}</span>
                <h3>{s.title}</h3>
                <p class="cf-text-muted">{s.body}</p>
              </li>
            ))}
          </ol>
        </div>
      </section>

      <!-- Demo -->
      <section id="demo" class="section">
        <div class="cf-container">
          <header class="section__head cf-reveal">
            <span class="cf-eyebrow">See it run</span>
            <h2>A 100-person FinOps review, live.</h2>
            <p class="section__lead">
              Watch a CTO ask a budget question, a CFO approve a scoped grant, and the brain answer —
              with the salary line redacted the whole way through.
            </p>
          </header>
          <div class="video cf-card cf-card--raised cf-reveal" style="--cf-reveal-delay: 120ms;">
            <div class="video__frame">
              <a class="cf-btn cf-btn--primary cf-btn--lg" href={demoUrl}>▶ Watch the demo</a>
            </div>
          </div>
          <p class="demo__links">
            <a href={demoUrl}>Open the live demo</a> · <a href={slidesUrl}>Read the deck</a>
          </p>
        </div>
      </section>
    </main>

    <footer class="footer">
      <div class="cf-container footer__inner">
        <div class="brand">
          {logoArt ? (
            <img class="brand__mark" src={logoArt.src} alt="" width={logoArt.width} height={logoArt.height} />
          ) : (
            <svg class="brand__mark" viewBox="0 0 32 32" aria-hidden="true">
              <defs>
                <linearGradient id="footmark" x1="0" y1="0" x2="32" y2="32" gradientUnits="userSpaceOnUse">
                  <stop offset="0" stop-color="#6366f1" />
                  <stop offset="1" stop-color="#0ea5e9" />
                </linearGradient>
              </defs>
              <rect width="32" height="32" rx="8" fill="url(#footmark)" />
              <path d="M22 11.4a7 7 0 1 0 0 9.2" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" />
              <circle cx="22.6" cy="16" r="2.6" fill="#f59e0b" />
            </svg>
          )}
          <span class="brand__name">Contextful</span>
        </div>
        <nav class="footer__links" aria-label="Footer">
          <a href={demoUrl}>Demo</a>
          <a href={slidesUrl}>Deck</a>
          <a href="https://www.contextful.work">contextful.work</a>
        </nav>
        <p class="footer__legal cf-text-muted">© 2026 Contextful · Local-first by design</p>
      </div>
    </footer>

    <style>
      .nav {
        position: sticky;
        top: 0;
        z-index: var(--z-sticky);
        background: color-mix(in srgb, var(--color-bg) 82%, transparent);
        backdrop-filter: saturate(140%) blur(10px);
        border-bottom: 1px solid var(--color-border);
      }
      .nav__inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 4rem;
      }
      .brand { display: inline-flex; align-items: center; gap: var(--space-2); color: var(--color-text); }
      .brand:hover { color: var(--color-text); }
      .brand__mark { width: 28px; height: 28px; }
      .brand__name { font-weight: var(--weight-bold); letter-spacing: var(--tracking-tight); font-size: var(--text-lg); }
      .nav__links { display: flex; align-items: center; gap: var(--space-6); }
      .nav__links a { color: var(--color-text-muted); font-size: var(--text-sm); font-weight: var(--weight-medium); }
      .nav__links a:hover { color: var(--color-text); }
      .nav__links a.cf-btn { color: var(--color-text-on-primary); }
      @media (max-width: 640px) {
        .nav__links a:not(.cf-btn) { display: none; }
      }

      .hero { position: relative; padding-block: var(--space-24) var(--space-16); background: var(--gradient-hero); }
      .hero__inner { position: relative; z-index: 1; display: grid; grid-template-columns: 1.1fr 0.9fr; gap: var(--space-12); align-items: center; }

      /* Ambient orbs — blurred brand-color shapes drifting behind (and
       * across) sections. */
      .orb {
        position: absolute;
        border-radius: var(--radius-full);
        pointer-events: none;
        filter: blur(64px);
        opacity: 0.5;
      }
      .orb--indigo { background: var(--cf-indigo-300); }
      .orb--sky { background: var(--cf-sky-300); }
      .orb--amber { background: var(--cf-amber-300); opacity: 0.45; }
      .hero__orb--1 { width: 24rem; height: 24rem; top: -7rem; left: -9rem; --cf-float-dur: 16s; --cf-float-amp: 36px; }
      .hero__orb--2 { width: 18rem; height: 18rem; bottom: -6rem; right: 6%; --cf-float-dur: 20s; --cf-float-amp: 44px; --cf-float-delay: -8s; }
      .how__orb { width: 16rem; height: 16rem; top: -8rem; right: 10%; --cf-float-dur: 18s; --cf-float-amp: 40px; }
      .hero__title { font-size: var(--text-6xl); margin-top: var(--space-4); }
      .hero__sub { margin-top: var(--space-6); font-size: var(--text-lg); color: var(--color-text-muted); max-width: 34rem; }
      .hero__cta { margin-top: var(--space-8); display: flex; gap: var(--space-3); flex-wrap: wrap; }
      .hero__note { margin-top: var(--space-4); font-size: var(--text-sm); color: var(--color-text-subtle); }

      main { overflow-x: clip; }

      .hero__visual { display: grid; }
      .hero__art {
        width: 118%;
        max-width: none;
        margin: -4% -12% 0 -6%;
      }
      .hero__art + .glimpse {
        margin-top: calc(-1 * var(--space-12));
        margin-inline: var(--space-8) var(--space-2);
      }
      .glimpse { padding: var(--space-5); }
      .glimpse__head { display: flex; align-items: center; justify-content: space-between; }
      .glimpse__title { font-weight: var(--weight-semibold); }
      .glimpse__line { margin-top: var(--space-4); font-weight: var(--weight-medium); }
      .glimpse__answer { margin-top: var(--space-4); padding: var(--space-4); background: var(--color-surface-sunken); border-radius: var(--radius-md); display: flex; flex-wrap: wrap; gap: var(--space-2); }
      .glimpse__answer p { width: 100%; margin-top: var(--space-2); font-size: var(--text-sm); color: var(--color-text-muted); }
      @media (max-width: 880px) { .hero__inner { grid-template-columns: 1fr; } .hero__visual { display: none; } }

      .strip { padding-block: var(--space-10); border-block: 1px solid var(--color-border); }
      .strip__label { text-align: center; font-size: var(--text-sm); color: var(--color-text-subtle); }
      .strip__tools { list-style: none; padding: 0; margin: var(--space-5) 0 0; display: flex; flex-wrap: wrap; justify-content: center; gap: var(--space-6); }
      .strip__tools li { font-weight: var(--weight-semibold); color: var(--color-text-muted); }

      .section { position: relative; padding-block: var(--space-24); }
      .section > .cf-container { position: relative; z-index: 1; }
      .section--alt { background: var(--color-surface-sunken); }
      .section__head { max-width: 42rem; margin-bottom: var(--space-12); }
      .section__head h2 { margin-top: var(--space-3); }
      .section__lead { margin-top: var(--space-4); font-size: var(--text-lg); color: var(--color-text-muted); }

      .grid { display: grid; gap: var(--space-6); }
      .grid--2 { grid-template-columns: repeat(2, 1fr); }
      .grid--3 { grid-template-columns: repeat(3, 1fr); }
      @media (max-width: 760px) { .grid--2, .grid--3 { grid-template-columns: 1fr; } }
      .cf-card h3 { margin-bottom: var(--space-2); }

      /* Feature art floats free of the card, breaking out of its top edge.
       * Offsets/rotation are --cf-float-* vars so the drift animation
       * composes with them. */
      #features .grid--2 { margin-top: var(--space-20); row-gap: var(--space-24); }
      .card__art {
        width: 58%;
        max-width: 15rem;
        margin: calc(-1 * var(--space-20)) auto var(--space-3);
      }
      #features article:nth-child(odd) .card__art { --cf-float-tx: -16%; --cf-float-rot: -2.5deg; }
      #features article:nth-child(even) .card__art { --cf-float-tx: 16%; --cf-float-rot: 2.5deg; --cf-float-tilt: -1deg; }

      /* The banner straddles the boundary between the features section and
       * this one — free-flow across sections. */
      .how__art {
        position: relative;
        z-index: 1;
        width: min(58rem, 94%);
        margin: calc(-1 * (var(--space-24) + var(--space-16))) auto var(--space-12);
      }

      .steps { list-style: none; padding: 0; }
      .step__n { font-family: var(--font-mono); font-size: var(--text-sm); color: var(--color-primary); font-weight: var(--weight-bold); }
      .step h3 { margin-top: var(--space-3); }

      .video { padding: var(--space-3); }
      .video__frame {
        aspect-ratio: 16 / 9;
        border-radius: var(--radius-md);
        display: grid;
        place-items: center;
        background: var(--gradient-brand-soft);
      }
      .demo__links { margin-top: var(--space-6); text-align: center; color: var(--color-text-muted); }

      .footer { border-top: 1px solid var(--color-border); padding-block: var(--space-12); }
      .footer__inner { display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: var(--space-4); }
      .footer__links { display: flex; gap: var(--space-5); }
      .footer__links a { color: var(--color-text-muted); font-size: var(--text-sm); }
      .footer__legal { width: 100%; font-size: var(--text-sm); }
    </style>

    <script>
      // Scroll reveals: gate hidden state on html.js (no-JS users see
      // everything), then let IntersectionObserver trigger entrances.
      document.documentElement.classList.add("js");
      const revealEls = document.querySelectorAll(".cf-reveal, .cf-reveal--fade");
      if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
        revealEls.forEach((el) => el.classList.add("is-visible"));
      } else {
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                io.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.15, rootMargin: "0px 0px -10% 0px" }
        );
        revealEls.forEach((el) => io.observe(el));
      }
    </script>
  </body>
</html>
